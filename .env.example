# ─── API ───────────────────────────────────────────────
EXPO_PUBLIC_API_URL=http://localhost:3000

# ─── Expo ──────────────────────────────────────────────
EXPO_PUBLIC_EXPO_PROJECT_ID=your-expo-project-id

# ─── Google Maps ───────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ─── Sentry (optional) ─────────────────────────────────
EXPO_PUBLIC_SENTRY_DSN=your-sentry-dsn

# ─── Backend (.env) ────────────────────────────────────
# Copy to backend/.env and fill in:
DATABASE_URL=postgresql://lovealarm:lovealarm@localhost:5432/lovealarm
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-this-to-a-secure-random-string-64-chars
JWT_REFRESH_SECRET=another-secure-random-string-64-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
PORT=3000

# SMS (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Firebase (Push Notifications)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# AWS S3 (Photos)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-central-1
AWS_S3_BUCKET=lovealarm-media

# Stripe (Premium)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# Dev OTP bypass (development only — remove in production)
DEV_OTP_CODE=123456
