{
  "expo": {
    "name": "Love Alarm",
    "slug": "love-alarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lovealarm",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0D0D1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lovealarm.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Love Alarm 10 metre yakınındaki kişileri tespit eder.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Uygulama kapalıyken de alarm çalabilmek için konum gerekli.",
        "NSLocationAlwaysUsageDescription": "Arka planda alarm için konum gerekli.",
        "NSCameraUsageDescription": "Profil fotoğrafı çekmek için kamera erişimi gerekli.",
        "NSMicrophoneUsageDescription": "Sesli mesaj göndermek için mikrofon erişimi gerekli.",
        "NSPhotoLibraryUsageDescription": "Galeriden fotoğraf seçmek için izin gerekli."
      },
      "config": {
        "googleMapsApiKey": "YOUR_IOS_MAPS_KEY"
      }
    },
    "android": {
      "package": "com.lovealarm.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FF5F8D"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_ANDROID_MAPS_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-location",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#FF5F8D",
          "sounds": ["./assets/sounds/alarm.mp3", "./assets/sounds/match.mp3"]
        }
      ],
      "expo-camera",
      [
        "expo-av",
        {
          "microphonePermission": "Sesli mesaj göndermek için mikrofon erişimi gerekli."
        }
      ],
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
